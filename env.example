# MapFlow SDK - Configuration Environment Variables
# Copiez ce fichier en .env et remplissez vos valeurs

# Clé API MapFlow (OBLIGATOIRE)
# Obtenez-la sur: https://app.mapflow.co/settings/api-keys
MAPFLOW_API_KEY=votre-cle-api-ici

# URL de base de l'API (OPTIONNEL)
# Par défaut: https://api.mapflow.co
# Pour les tests: https://api-test.mapflow.co
MAPFLOW_BASE_URL=https://api.mapflow.co

# Timeout des requêtes en secondes (OPTIONNEL)
# Par défaut: 30
MAPFLOW_TIMEOUT=30

